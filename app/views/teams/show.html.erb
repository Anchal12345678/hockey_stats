<div class="row">
  <div class="col-md-4">
    <div class="card shadow mb-4">
      <div class="card-header bg-dark text-white">
        <h3 class="mb-0"><%= @team.name %></h3>
      </div>
      <div class="card-body">
        <p><strong>City:</strong> <%= @team.city %></p>
        <p><strong>Conference:</strong> <%= @team.conference %></p>
        <p><strong>Division:</strong> <%= @team.division %></p>
        <p><strong>Players:</strong> <%= @team.players.count %></p>
        <p><strong>Full Name:</strong> <%= @team.city %> <%= @team.name %></p>
      </div>
    </div>
    <%= link_to "← Back to All Teams", teams_path, class: "btn btn-secondary mt-2" %>
  </div>

  <div class="col-md-8">
    <h3>Roster</h3>
    <table class="table table-striped table-hover">
      <thead class="table-dark">
        <tr>
          <th>Name</th>
          <th>Position</th>
          <th>Nationality</th>
          <th>Date of Birth</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @players.each do |player| %>
          <tr>
            <td><%= player.first_name %> <%= player.last_name %></td>
            <td><%= player.position %></td>
            <td><%= player.nationality %></td>
            <td><%= player.date_of_birth&.strftime("%b %d, %Y") %></td>
            <td><%= link_to "View", player_path(player), class: "btn btn-sm btn-outline-dark" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>