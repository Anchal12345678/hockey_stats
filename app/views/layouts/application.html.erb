<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Hockey Stats</title>
    <meta name="description" content="NHL Hockey Stats - Browse teams, players and statistics">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand" href="/">🏒 Hockey Stats</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
          <ul class="navbar-nav">
  <li class="nav-item">
    <%= link_to "Home", root_path, class: "nav-link #{'active' if request.path == '/'}" %>
  </li>
  <li class="nav-item">
    <%= link_to "Teams", teams_path, class: "nav-link #{'active' if request.path.start_with?('/teams')}" %>
  </li>
  <li class="nav-item">
    <%= link_to "Players", players_path, class: "nav-link #{'active' if request.path.start_with?('/players')}" %>
  </li>
  <li class="nav-item">
    <%= link_to "Stats Leaderboard", stats_path, class: "nav-link #{'active' if request.path.start_with?('/stats')}" %>
  </li>
  <li class="nav-item">
    <%= link_to "About", about_path, class: "nav-link #{'active' if request.path == '/about'}" %>
  </li>
</ul>
        </div>
      </div>
    </nav>

    <div class="container mt-4">
      <%= yield %>
    </div>

    <footer class="bg-dark text-white text-center py-3 mt-5">
  <p class="mb-0">🏒 Hockey Stats App &copy; 2025 |
    <%= link_to "Teams", teams_path, class: "text-white ms-2" %> |
    <%= link_to "Players", players_path, class: "text-white ms-2" %> |
    <%= link_to "About", about_path, class: "text-white ms-2" %>
  </p>
</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>