<h1>Players</h1>
<hr>

<div class="card mb-4 shadow-sm">
  <div class="card-body">
    <%= form_with url: players_path, method: :get, local: true do |f| %>
      <div class="row g-2">
        <div class="col-md-5">
          <%= f.text_field :search, value: params[:search], placeholder: "Search by name, position, nationality...", class: "form-control" %>
        </div>
        <div class="col-md-4">
          <%= f.select :team_id,
            options_from_collection_for_select(Team.order(:name), :id, :name, params[:team_id]),
            { include_blank: "-- Filter by Team --" },
            { class: "form-select" } %>
        </div>
        <div class="col-md-2">
          <%= f.submit "Search", class: "btn btn-dark w-100" %>
        </div>
        <div class="col-md-1">
          <%= link_to "Clear", players_path, class: "btn btn-outline-secondary w-100" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

<p class="text-muted">Showing <%= @players.total_count %> players</p>

<table class="table table-striped table-hover shadow-sm">
  <thead class="table-dark">
    <tr>
      <th>Name</th>
      <th>Position</th>
      <th>Nationality</th>
      <th>Team</th>
      <th>Date of Birth</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @players.each do |player| %>
      <tr>
        <td><%= player.first_name %> <%= player.last_name %></td>
        <td><%= player.position %></td>
        <td><%= player.nationality %></td>
        <td><%= link_to player.team.name, team_path(player.team) %></td>
        <td><%= player.date_of_birth&.strftime("%b %d, %Y") %></td>
        <td><%= link_to "View", player_path(player), class: "btn btn-sm btn-outline-dark" %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @players %>