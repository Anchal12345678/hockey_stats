<h1>📊 Stats Leaderboard</h1>
<hr>

<table class="table table-striped table-hover shadow-sm">
  <thead class="table-dark">
    <tr>
      <th>#</th>
      <th>Player</th>
      <th>Team</th>
      <th>Season</th>
      <th>GP</th>
      <th>Goals</th>
      <th>Assists</th>
      <th>Points</th>
      <th>+/-</th>
    </tr>
  </thead>
  <tbody>
    <% @stats.each_with_index do |stat, index| %>
      <tr>
        <td><%= ((@stats.current_page - 1) * 25) + index + 1 %></td>
        <td><%= link_to "#{stat.player.first_name} #{stat.player.last_name}", player_path(stat.player) %></td>
        <td><%= link_to stat.player.team.name, team_path(stat.player.team) %></td>
        <td><%= stat.season %></td>
        <td><%= stat.games_played %></td>
        <td><%= stat.goals %></td>
        <td><%= stat.assists %></td>
        <td><strong><%= stat.points %></strong></td>
        <td><%= stat.plus_minus %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<%= paginate @stats %>